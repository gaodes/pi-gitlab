{
	"name": "@gaodes/pi-gitlab",
	"version": "0.1.0",
	"description": "Pi extension package for GitLab workflows via glab CLI with in-package skills.",
	"keywords": [
		"pi-package",
		"pi-extension",
		"gitlab",
		"glab"
	],
	"type": "module",
	"private": false,
	"main": "./src/index.ts",
	"files": [
		"src",
		"skills",
		"README.md",
		"CHANGELOG.md",
		"LICENSE",
		".upstream.json",
		".primecodex.json"
	],
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome check --write .",
		"test": "vitest run --passWithNoTests"
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		],
		"skills": [
			"./skills"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.3",
		"@earendil-works/pi-coding-agent": "^0.78.0",
		"@types/node": "^22.0.0",
		"typebox": "^1.1.39",
		"typescript": "^5.6.2",
		"vitest": "^4.1.5"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": ">=0.74.0 <1",
		"@earendil-works/pi-coding-agent": ">=0.74.0 <1",
		"@earendil-works/pi-tui": ">=0.74.0 <1",
		"typebox": ">=1.1.0 <2"
	},
	"peerDependenciesMeta": {
		"@earendil-works/pi-ai": {
			"optional": true
		},
		"@earendil-works/pi-coding-agent": {
			"optional": true
		},
		"@earendil-works/pi-tui": {
			"optional": true
		},
		"typebox": {
			"optional": true
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gaodes/pi-gitlab.git"
	},
	"license": "MIT",
	"author": "El Che"
}
